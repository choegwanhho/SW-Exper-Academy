#include <iostream>
 
using namespace std;
 
int arr[12][12] = { 0, };
 
void move(int N, int w, int h, int way, int v)
{
    if (v == N * N)
    {
        arr[w][h] = v;
        return;
    }       
    switch (way)
    {
        case 1:
        {
            //cout << "우\n";
            while ( (w <= N) && ( arr[w][h] == 0 ) )
            {
                arr[w][h] = v;
                //cout << "w: " << w << " h: " << h << " v: " << v << endl;
                w++;
                v++;                
                //cout << "w: " << w << " h: " << h << " v: " << v << endl;
            }           
            move(N, w-1, h+1, 2, v);
            return;
        }
        case 2:
        {
            //cout << "하\n";
            while ( ( h <= N ) && ( arr[w][h] == 0 ) )
            {
                arr[w][h] = v;
                //cout << "w: " << w << " h: " << h << " v: " << v << endl;
                h++;
                v++;
                //cout << "w: " << w << " h: " << h << " v: " << v << endl;
            }
            move(N, w-1, h-1, 3, v);
            return;
        }
        case 3:
        {
            //cout << "좌\n";
            while ( ( 0 < w ) && ( arr[w][h] == 0 ) )
            {
                arr[w][h] = v;
                //cout << "w: " << w << " h: " << h << " v: " << v << endl;
                w--;
                v++;
                //cout << "w: " << w << " h: " << h << " v: " << v << endl;
            }
            move(N, w+1, h-1, 4, v);
            return;
        }
        case 4:
        {
            //cout << "상\n";
            while( ( 0 < h ) && ( arr[w][h] == 0 ) )
            {
                arr[w][h] = v;
                //cout << "w: " << w << " h: " << h << " v: " << v << endl;
                h--;
                v++;
                //cout << "w: " << w << " h: " << h << " v: " << v << endl;
            }
            move(N, w+1, h+1, 1, v);
            return;
        }
    }       
}
 
int main()
{
    int T = 0;                // 테스트 케이스 갯수
    int N = 0;                // 달팽이의 크기    (1<= N <= 10)
     
    cin >> T;
 
    for (int a = 0; a < T; a++)  // 테스트 케이스만큼 반복
    {
        int w = 1;                // 가로 좌표값
        int h = 1;                // 세로 좌표값
        int way = 1;              // 방향 변수(1:우측, 2:하단, 3:좌측, 4:상단)
        int v = 1;
 
        cin >> N;
         
        move(N,w, h,way,v);
 
        cout << "#" << N << endl;
        for (int b = 1; b <= N; b++)     // 세로 좌표
        {
            for (int c = 1; c <= N; c++) // 가로 좌표
            {
                cout << arr[c][b] << " ";
                arr[c][b] = 0;
            }
            cout << endl;
        }
    }
}
