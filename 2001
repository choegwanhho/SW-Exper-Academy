#include < iostream >
#include < vector >

using namespace std;

int main()
{
    int T = 0;
    cin >> T;
    
    for (int i = 0; i < T; i++) 
    {
        int N = 0; // 입력받을 배열의 크기 (5<= N<= 15)
        int M = 0; // 파리채의 크기 (2<= M<= N)
        
        cin >> N >>M;

        vector<vector<int>> arr(N, vector<int>(N));

        for (int j = 0; j < N; j++) 
            for (int k = 0; k < N; k++) 
                cin >> arr[j][k];
        


        cout << endl;
    }

}
