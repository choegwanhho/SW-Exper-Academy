#include <iostream>
#include <cstdio>
#include <algorithm>
 
using namespace std;
 
int main()
{
    int N = 0; 
    int H[1000] = { 0 }; 
    int sum = 0; 
 
    for (int i = 0; i < 10; i++) 
    {
        sum = 0;  
        cin >> N;
 
        for (int j = 0; j < N; j++)
        {
            cin >> H[j];                  
        }
 
        for (int j = 2; j < N - 2; j++) 
        {
            if ( H[j] > max( max(H[j - 2], H[j - 1]), max(H[j + 2], H[j + 1])) )   
                sum += H[j] - max(max(H[j - 2], H[j - 1]), max(H[j + 2], H[j + 1])); 
        }
        cout << "#" << i+1 << " " << sum << endl;
    }
 
}
