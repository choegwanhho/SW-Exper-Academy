#include <iostream>
#include <iomanip>

using namespace std;

// 입력받은 값을 YYYY/MM/DD 형식으로 출력, 유효하지 않으면 -1 출력
// 2월은 28일까지, 4,6,9,11월은 30일까지, 나머지 달은 31일까지

int main()
{
	int T = 0; 	
	cin >> T;

	for (int i = 1; i <= T; i++)
	{
		cout << "#" << i << " "; 

		int year = 0;
		int month = 0;
		int day = 0;   
		
		cin >> year;

		// 입력받은 값을 일 월 년으로 나누기
		day = year % 100;
		year = year / 100;

		month = year % 100;
		year = year / 100;

		if (( (month == 2) && (1 <= day && day <= 28) ) || 
			(((month == 4) || (month == 6) || (month == 9) || (month == 11)) && (1 <= day && day <= 30)) || 
			(((month == 1) || (month == 3) || (month == 5) || (month == 7) || (month == 8) || (month == 10) || (month == 12)) && (1 <= day && day <= 31)) )
		{
			//printf("%04d/%02d/%02d\n", year, month, day);
			cout << setfill('0')
				<< setw(4) << year << "/"
				<< setw(2) << month << "/"
				<< setw(2) << day << "\n";
		}
		else
		{
			cout << "-1" << endl;
		}
	}
	return 0;
}
