#include <iostream>
#include <cmath>
 
using namespace std;
 
int main()
{
    int T = 0;       // 테스트 케이스 갯수
    int arr = 0;     // 입력받을 10개의 수 (0 <= arr <= 10000 )
    double ans = 0;  // 수를 모두 합해서 평균값 
 
    cin >> T;
 
    for (int a = 0; a < T; a++)
    {
        cout << "#" << a+1 << " ";
 
        for (int b = 0 ; b < 10 ; b++)
        {
            cin >> arr;
            ans += arr;
        }
        cout << round(ans/10) << endl;
        ans = 0;
    }
}
